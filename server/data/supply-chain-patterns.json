      "byebug", "tzinfo", "i18n", "json", "concurrent-ruby"
    ]
  },
  "postinstallRedFlags": [
    { "id": "postinstall-curl", "pattern": "(?:^|[^a-zA-Z])curl\\s+", "severity": "High", "reason": "install script fetches remote content via curl" },
    { "id": "postinstall-wget", "pattern": "(?:^|[^a-zA-Z])wget\\s+", "severity": "High", "reason": "install script fetches remote content via wget" },
    { "id": "postinstall-http-pipe", "pattern": "https?://[^\\s'\"]+\\s*\\|", "severity": "High", "reason": "install script pipes remote URL into shell" },
    { "id": "postinstall-dyn-eval", "pattern": "\\b(?:e)(?:v)(?:a)(?:l)\\s*[\\(`]", "severity": "High", "reason": "install script evaluates code dynamically" },
    { "id": "postinstall-base64-decode", "pattern": "base64\\s+(?:-d|--decode)", "severity": "High", "reason": "install script decodes base64 payload" },
    { "id": "postinstall-netcat", "pattern": "(?:^|[^a-zA-Z])nc\\s+-", "severity": "High", "reason": "install script uses netcat" },
    { "id": "postinstall-write-outside", "pattern": "(?:~/|\\$HOME/|/etc/|/root/|/usr/local/)", "severity": "Medium", "reason": "install script writes outside project tree" },
    { "id": "postinstall-spawn", "pattern": "child_process\\.|require\\(['\"]child_process['\"]\\)", "severity": "Medium", "reason": "install script spawns child process" },
    { "id": "postinstall-network-lib", "pattern": "(?:node-fetch|axios|got|undici|https?\\.get)\\s*\\(", "severity": "High", "reason": "install script performs network fetch" },
    { "id": "postinstall-chmod-x", "pattern": "chmod\\s+[0-7]*x", "severity": "Medium", "reason": "install script marks file executable" },
    { "id": "postinstall-dynamic-require", "pattern": "require\\(\\s*Buffer\\.from", "severity": "High", "reason": "install script uses dynamic require from Buffer" }
  ],
  "secretRegexes": [
    { "id": "aws-access-key", "pattern": "\\bAKIA[0-9A-Z]{16}\\b", "description": "AWS Access Key ID", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "aws-secret-key", "pattern": "(?i)aws(.{0,20})?(secret|private)[\\s=:\"']{1,5}([A-Za-z0-9/+=]{40})", "description": "AWS Secret Access Key", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "gcp-service-account", "pattern": "\"type\":\\s*\"service_account\"", "description": "GCP service-account credential JSON", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "gcp-api-key", "pattern": "\\bAIza[0-9A-Za-z_-]{35}\\b", "description": "Google API key", "severity": "High", "cwe": "CWE-798" },
    { "id": "azure-storage-key", "pattern": "DefaultEndpointsProtocol=https?;AccountName=[^;]+;AccountKey=[A-Za-z0-9+/=]{60,}", "description": "Azure Storage connection string with account key", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "ssh-private-key", "pattern": "-----BEGIN (?:RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY", "description": "SSH/PGP private key", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "jwt-hardcoded", "pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b", "description": "Hardcoded JWT", "severity": "High", "cwe": "CWE-798" },
    { "id": "bearer-token", "pattern": "(?i)bearer\\s+[A-Za-z0-9._~+/=-]{20,}", "description": "Bearer token", "severity": "High", "cwe": "CWE-798" },
    { "id": "slack-token", "pattern": "\\bxox[baprs]-[A-Za-z0-9-]{10,}", "description": "Slack API token", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "slack-webhook", "pattern": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]{20,}", "description": "Slack webhook URL", "severity": "High", "cwe": "CWE-798" },
    { "id": "discord-webhook", "pattern": "https://(?:ptb\\.|canary\\.)?discord(?:app)?\\.com/api/webhooks/\\d+/[A-Za-z0-9_-]{40,}", "description": "Discord webhook URL", "severity": "High", "cwe": "CWE-798" },
    { "id": "discord-token", "pattern": "(?i)discord[^\\n]{0,40}['\"][MN][A-Za-z0-9]{23}\\.[\\w-]{6}\\.[\\w-]{27}['\"]", "description": "Discord bot token", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "github-token", "pattern": "\\bgh[pousr]_[A-Za-z0-9]{36}\\b", "description": "GitHub personal access token", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "github-oauth", "pattern": "\\bgho_[A-Za-z0-9]{36}\\b", "description": "GitHub OAuth token", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "stripe-live", "pattern": "\\b(?:sk|rk)_live_[A-Za-z0-9]{24,}\\b", "description": "Stripe live secret key", "severity": "Critical", "cwe": "CWE-798" },
    { "id": "stripe-test", "pattern": "\\b(?:sk|rk)_test_[A-Za-z0-9]{24,}\\b", "description": "Stripe test secret key", "severity": "Medium", "cwe": "CWE-798" },
    { "id": "db-conn-postgres", "pattern": "postgres(?:ql)?://[^\\s:]+:[^\\s@]+@[^\\s/]+", "description": "Postgres connection string with password", "severity": "High", "cwe": "CWE-798" },
    { "id": "db-conn-mysql", "pattern": "mysql://[^\\s:]+:[^\\s@]+@[^\\s/]+", "description": "MySQL connection string with password", "severity": "High", "cwe": "CWE-798" },
    { "id": "db-conn-mongo", "pattern": "mongodb(?:\\+srv)?://[^\\s:]+:[^\\s@]+@[^\\s/]+", "description": "MongoDB connection string with password", "severity": "High", "cwe": "CWE-798" },
    { "id": "generic-password-assign", "pattern": "(?i)(?:password|passwd|pwd)\\s*[=:]\\s*[\"']([^\"'\\s]{8,})[\"']", "description": "Hardcoded password assignment", "severity": "High", "cwe": "CWE-798" },
    { "id": "generic-api-key", "pattern": "(?i)(?:api[_-]?key|apikey|secret[_-]?key)\\s*[=:]\\s*[\"']([A-Za-z0-9_-]{20,})[\"']", "description": "Hardcoded API-key assignment", "severity": "High", "cwe": "CWE-798" }
  ],
  "cryptoRedFlags": [
    { "id": "math-random-token", "pattern": "Math\\.random\\s*\\(\\s*\\)", "contextPattern": "(?i)(?:token|secret|session|key|nonce|salt|otp|password|reset|uuid|id)", "contextWindow": 2, "description": "Math.random() used for security-sensitive value", "severity": "High", "cwe": "CWE-338", "languages": ["JavaScript", "TypeScript"], "remediation": "Use crypto.randomBytes() / crypto.getRandomValues() / crypto.randomUUID()" },
    { "id": "md5-password", "pattern": "(?i)(?:md5|createHash\\(['\"]md5['\"]\\))", "contextPattern": "(?i)(?:password|passwd|hash)", "contextWindow": 5, "description": "MD5 used with password data", "severity": "High", "cwe": "CWE-327", "languages": [], "remediation": "Use bcrypt, scrypt, argon2, or PBKDF2 with a high iteration count" },
    { "id": "sha1-password", "pattern": "(?i)(?:createHash\\(['\"]sha1['\"]\\)|hashlib\\.sha1|SHA1\\b)", "contextPattern": "(?i)(?:password|passwd)", "contextWindow": 5, "description": "SHA1 used with password data", "severity": "High", "cwe": "CWE-327", "languages": [], "remediation": "Use bcrypt, scrypt, argon2, or PBKDF2 with a high iteration count" },
    { "id": "des-cipher", "pattern": "(?i)(?:createCipher(?:iv)?\\(['\"]des|DESede|Cipher\\.getInstance\\(['\"]DES)", "description": "Weak DES/3DES cipher", "severity": "High", "cwe": "CWE-327", "languages": [], "remediation": "Use AES-256-GCM" },
    { "id": "rc4-cipher", "pattern": "(?i)(?:rc4|arcfour)", "description": "Weak RC4 cipher", "severity": "High", "cwe": "CWE-327", "languages": [], "remediation": "Use AES-256-GCM" },
    { "id": "ecb-mode", "pattern": "(?i)(?:aes-\\d+-ecb|/ECB/|Cipher\\.getInstance\\(['\"]AES/ECB)", "description": "ECB cipher mode leaks patterns", "severity": "High", "cwe": "CWE-327", "languages": [], "remediation": "Use GCM or CBC with random IV" },
    { "id": "hardcoded-iv", "pattern": "(?i)iv\\s*[=:]\\s*(?:[\"'][A-Za-z0-9+/=]{8,}[\"']|Buffer\\.from\\([\"'][A-Fa-f0-9]{8,}[\"'])", "description": "Hardcoded initialization vector", "severity": "High", "cwe": "CWE-329", "languages": [], "remediation": "Generate a fresh random IV per message" },
    { "id": "hardcoded-crypto-key", "pattern": "(?i)(?:crypto|cipher|secret|encryption)[_-]?key\\s*[=:]\\s*[\"'][A-Za-z0-9+/=]{16,}[\"']", "description": "Hardcoded encryption key", "severity": "High", "cwe": "CWE-798", "languages": [], "remediation": "Load keys from env vars or a secret manager" },
    { "id": "srand-time", "pattern": "srand\\s*\\(\\s*time\\s*\\(", "description": "srand(time(NULL)) predictable PRNG seed", "severity": "High", "cwe": "CWE-337", "languages": ["C", "C++"], "remediation": "Use getrandom(), /dev/urandom, or a CSPRNG" },
    { "id": "rand-modulo", "pattern": "\\brand\\s*\\(\\s*\\)\\s*%\\s*\\w+", "contextPattern": "(?i)(?:session|token|id|key|secret|nonce|salt)", "contextWindow": 3, "description": "rand() % n used for security-sensitive value", "severity": "High", "cwe": "CWE-338", "languages": ["C", "C++"], "remediation": "Use a CSPRNG such as arc4random_uniform() or getrandom()" },
    { "id": "python-random-token", "pattern": "(?<!secrets\\.)(?:random\\.random|random\\.randint|random\\.choice|random\\.sample)", "contextPattern": "(?i)(?:token|secret|session|key|password|reset|otp)", "contextWindow": 3, "description": "Python random module used for security-sensitive value (use secrets module)", "severity": "High", "cwe": "CWE-338", "languages": ["Python"], "remediation": "Use secrets.token_bytes / secrets.token_urlsafe" }
  ],
  "backdoorRoutePatterns": [
    { "id": "header-equality-bypass-js", "pattern": "req\\.headers\\[[\"']x-[a-z0-9-]+[\"']\\]\\s*===?\\s*[\"'][^\"']+[\"']", "description": "Authentication bypass via exact header-value match", "severity": "High", "cwe": "CWE-287", "frameworks": ["Express", "Koa", "Fastify"], "remediation": "Use proper authentication middleware (JWT, session, OAuth) instead of header equality" },
    { "id": "header-equality-bypass-py", "pattern": "request\\.headers\\.get\\(\\s*[\"'][Xx]-[A-Za-z0-9-]+[\"']\\s*\\)\\s*==\\s*[\"'][^\"']+[\"']", "description": "Authentication bypass via exact header-value match (Python)", "severity": "High", "cwe": "CWE-287", "frameworks": ["Flask", "FastAPI", "Django"], "remediation": "Use framework authentication (Flask-Login, FastAPI Depends, Django auth middleware)" },
    { "id": "debug-flag-bypass", "pattern": "(?:process\\.env\\.DEBUG|os\\.environ\\[[\"']DEBUG[\"']\\]|os\\.getenv\\([\"']DEBUG[\"']\\))", "contextPattern": "(?i)(?:admin|auth|bypass|skip|grant|allow|backdoor|super)", "contextWindow": 8, "description": "Authentication bypass gated on DEBUG env flag", "severity": "High", "cwe": "CWE-489", "frameworks": ["Express", "Koa", "Fastify", "Flask", "FastAPI", "Django"], "remediation": "Remove debug-only auth bypass or guard on build flags stripped in production" },
    { "id": "ip-allowlist-bypass", "pattern": "(?:127\\.0\\.0\\.1|::1|localhost)", "contextPattern": "(?i)(?:x-forwarded-for|req\\.ip|request\\.remote_addr|getHeader)", "contextWindow": 6, "description": "IP allowlist trusts X-Forwarded-For header (client-controlled)", "severity": "High", "cwe": "CWE-290", "frameworks": ["Express", "Koa", "Fastify", "Flask", "FastAPI", "Django"], "remediation": "Use trust proxy settings safely; never trust X-Forwarded-For without a verified reverse proxy" },
    { "id": "time-bomb-js", "pattern": "(?:new\\s+Date\\s*\\(\\s*[\"']20[2-9]\\d|Date\\.now\\s*\\(\\s*\\)\\s*[<>]=?\\s*\\d{10,})", "contextPattern": "(?i)(?:admin|auth|exec|spawn|rm\\s|delete|drop\\s|unlink)", "contextWindow": 5, "description": "Date comparison near auth/RCE sink (possible time-bomb)", "severity": "High", "cwe": "CWE-511", "frameworks": ["Express", "Koa", "Fastify"], "remediation": "Remove time-bomb logic; audit commit history for author of the comparison" },
    { "id": "time-bomb-py", "pattern": "(?:datetime\\.now\\s*\\(\\s*\\)\\s*[<>]|datetime\\.today\\s*\\(\\s*\\)\\s*[<>]|time\\.time\\s*\\(\\s*\\)\\s*[<>]=?\\s*\\d{10,})", "contextPattern": "(?i)(?:admin|auth|exec|subprocess|os\\.system|pickle)", "contextWindow": 5, "description": "Date/time comparison near auth/RCE sink (possible time-bomb)", "severity": "High", "cwe": "CWE-511", "frameworks": ["Flask", "FastAPI", "Django"], "remediation": "Remove time-bomb logic; audit commit history" }
  ],
  "obfuscationPatterns": [],
  "customCryptoHints": {
    "functionNames": ["encrypt", "decrypt", "hash", "cipher", "obfuscate", "scramble", "encode_secret", "my_hash"],
    "knownImports": [
      "crypto", "node:crypto", "crypto-js", "bcrypt", "bcryptjs", "argon2",
      "hashlib", "cryptography", "nacl", "pynacl", "secrets",
      "javax.crypto", "java.security", "org.bouncycastle",
      "openssl/evp.h", "sodium", "libsodium", "mbedtls", "crypto/rand"
    ]
  }
}
