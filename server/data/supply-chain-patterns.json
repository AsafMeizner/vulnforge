{
  "_schema": {
    "version": 1,
    "description": "Pattern database for the supply-chain & backdoor detector (Track F). Consumers: server/pipeline/supply-chain/*.ts.",
    "fields": {
      "topPackages": "Per-ecosystem list of popular package names used for typosquatting edit-distance checks.",
      "postinstallRedFlags": "Array of {id, pattern, severity, reason} describing dangerous substrings in npm install scripts.",
      "secretRegexes": "Array of {id, pattern, description, severity, cwe} for git-history secret scanning.",
      "cryptoRedFlags": "Array of {id, pattern, description, severity, cwe, languages, remediation} for weak/backdoored crypto detection.",
      "backdoorRoutePatterns": "Array of {id, pattern, description, severity, cwe, frameworks, remediation} for hidden-admin route detection.",
      "obfuscationPatterns": "Array of {id, pattern, description, severity, cwe, remediation} for suspicious/obfuscated payloads.",
      "severityMap": "Canonical severity mapping for subsystem outputs.",
      "entropyThresholds": "Shannon entropy thresholds for flagging suspicious blobs.",
      "skipDirs": "Directory names skipped during file traversal.",
      "codeExtensions": "File extensions treated as source code."
    }
  },
  "severityMap": {
    "typosquat": "Critical",
    "malicious_postinstall": "High",
    "postinstall_network": "High",
    "recently_published": "Medium",
    "maintainer_churn": "Medium",
    "secret_in_history": "Critical",
    "weak_crypto": "Medium",
    "hardcoded_key": "High",
    "custom_crypto": "Medium",
    "hidden_route": "Medium",
    "header_bypass": "High",
    "debug_bypass": "High",
    "time_bomb": "High",
    "obfuscation": "Medium",
    "binary_blob": "Low",
    "deleted_restored": "High"
  },
  "entropyThresholds": {
    "base64Blob": 4.5,
    "hexBlob": 3.8,
    "minBlobLength": 1024
  },
  "skipDirs": [
    ".git", "node_modules", "vendor", "__pycache__", "target",
    "build", "dist", ".next", ".cache", "coverage",
    "__fixtures__", "fixtures", "testdata"
  ],
  "codeExtensions": [
    ".js", ".mjs", ".cjs", ".ts", ".tsx", ".jsx",
    ".py", ".rb", ".php", ".go", ".java", ".kt",
    ".cs", ".c", ".cpp", ".cc", ".h", ".hpp",
    ".rs", ".swift", ".scala", ".pl", ".sh", ".bash"
  ],
  "binaryExtensions": [".bin", ".dat", ".pyc", ".pyo", ".so", ".dll", ".dylib", ".class", ".exe", ".o", ".a", ".lib"],
