# Dependencies
node_modules/

# Build outputs
dist/
*.tsbuildinfo

# Database
vulnforge.db

# Data (cloned repos, temp files)
data/repos/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Temp
tmp/
.tmp/

# Local task tracking (private to devs + AI assistants, not for the repo)
/todo/

# Brand source files (Affinity Designer + locks). Exported web-safe copies
# live in /public/brand and /docs/assets - those ARE committed.
/logo/

# Plugin installs (external repos cloned by the plugin manager at runtime).
# Manifests in plugins/<Tool>/manifest.json ARE committed - just not the binaries.
/plugins/OWASP-Nettacker/

# Docs auto-generated reference output
/docs/reference/

# Claude Code session-local settings
/.claude/

# Compiled server output (from npm run build:server / tsc -p tsconfig.server.json)
/dist-server/
/dist-tarball-stage/

# Electron installer output (from npm run build:desktop)
/release/
/release2/
/release3/
/release4/
/release5/
/release6/
/release-artifacts/
/release*/
# Runtime port discovery file written by server startup for vite to read
/.vulnforge-port

# Playwright MCP scratch dir + screenshots from local probing
/.playwright-mcp/
/dashboard-initial.png
/scanner-after-fix.png
/scanner-reloaded.png
/scanner.png
/page-*.png

# Server tarball + docker artifacts (copied into release-artifacts/ by
# the release script)
/vulnforge-server-*.tar.gz
/vulnforge-server-*.tar
/vulnforge-server-*.docker

# Electron main/preload compiled output (tsc from tsconfig.electron.json).
# Generated files; the source of truth is electron/*.ts.
/electron/main.js
/electron/preload.js
/electron/*.js.map

# Superpowers specs (local only)
docs/superpowers/

# Project-level Claude Code config (local only)
.claude/
