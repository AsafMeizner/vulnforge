{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "sourceMap": false,
    "declaration": false,
    "resolveJsonModule": true,

    // Compile electron/main.ts and electron/preload.ts in-place so the
    // packaged app can load them as .js. The build-desktop script and
    // the electron:dev script both run this config before launching
    // Electron.
    "outDir": "./electron",
    "rootDir": "./electron",
    "noEmitOnError": false
  },
  // preload.ts is compiled by `tsconfig.electron-preload.json` as CJS
  // (Electron's preload sandbox doesn't accept ESM). Excluding it here
  // avoids double-compiling it with the wrong module format and
  // overwriting the correct output.
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules", "electron/**/*.test.ts", "electron/preload.ts"]
}
