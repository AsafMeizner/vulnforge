# VulnForge team server — example env file.
# Copy to `.env.server` and edit. DO NOT commit your real file.

# Public URL the server is reachable at (used for OIDC redirects + client config).
VULNFORGE_PUBLIC_URL=https://vulnforge.acme.corp

# Host port mapping (default 3001).
VULNFORGE_PORT=3001

# REQUIRED — generate with: openssl rand -base64 48
# Rotating this invalidates every outstanding access + refresh token.
VULNFORGE_JWT_SECRET=

# First-admin bootstrap — generate with: openssl rand -hex 24
# Server prints it on first start; paste into /api/session/bootstrap.
# Delete this line once bootstrap is complete.
VULNFORGE_BOOTSTRAP_TOKEN=

# Optional — suggestion for the first admin's email.
VULNFORGE_ADMIN_EMAIL=admin@acme.corp
