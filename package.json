{
  "name": "vulnforge",
  "version": "0.1.0",
  "description": "AI-powered security research platform - find, triage, and fix vulnerabilities",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "electron/main.js",
  "bin": {
    "vulnforge": "cli/vulnforge.mjs"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:server:team": "cross-env VULNFORGE_MODE=server tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.electron-preload.json",
    "build:server:tar": "node scripts/build-server-tar.mjs",
    "build:server:docker": "node scripts/build-server-docker.mjs",
    "build:desktop": "node scripts/build-desktop.mjs",
    "release": "node scripts/release.mjs",
    "migrate": "node scripts/migrate.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist-server/server/index.js",
    "start:server": "node dist-server/server/index.js",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"tsx watch server/index.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && npm run build:server && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.77.0",
    "sql.js": "^1.11.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "i18next": "^23.15.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.vulnforge.app",
    "productName": "VulnForge",
    "directories": {
      "output": "release",
      "buildResources": "public/brand"
    },
    "files": [
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.test.*",
      "!**/__fixtures__/**",
      "!electron/*.map",
      "dist/**/*",
      "dist-server/**/*",
      "electron/main.js",
      "electron/preload.js",
      "server/data/**/*",
      "server/ai/prompts/**/*.js",
      "server/checklists/**/*.js",
      "checklists/**/*.json",
      "assets/**/*",
      "public/brand/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/brand/logo-square.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/brand/logo-square.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/brand/logo-square.png"
    }
  }
}
