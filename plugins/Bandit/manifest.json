{
  "name": "Bandit",
  "version": "latest",
  "type": "scanner",
  "description": "Security linter for Python code — finds common security issues",
  "install_command": "pip install bandit",
  "run_command": "bandit -r {target} -f json -o {output}",
  "parse_output": "json",
  "requires": [
    "python3"
  ]
}